<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>ViiLab - Dashboard</title>
  <link rel="icon" type="image/jpeg" href="/logo.jpg">
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <div class="card">
    <div class="topbar">
      <h1 style="display: flex; align-items: center; gap: 0.75rem;">
        <img src="/logo.jpg" alt="Logo" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);">
        Welcome, <%= user.display_name %>
      </h1>
      <a href="/logout">Log out</a>
    </div>
    <h2>Your notes</h2>
    <ul class="note-list">
      <% notes.forEach(n=> { %>
        <li><a href="/notes/<%= n.id %>">#<%= n.id %> — <%= n.title %></a></li>
        <% }) %>
          <% if (notes.length===0) { %>
            <li>No notes yet.</li>
            <% } %>
    </ul>
    <a href="/notes/new"><button>+ New note</button></a>
    
    <div style="display: flex; gap: 1rem; margin-top: 1rem;">
      <a href="/board" style="flex: 1;"><button style="margin-top: 0; background: #6b7280;">🌐 Community Board</button></a>
      <a href="/admin" style="flex: 1;"><button style="margin-top: 0; background: #9f1239;">🛠️ Admin Panel</button></a>
    </div>
    <p class="hint">Try changing the note ID in the URL bar — do you see other users' notes?</p>
  </div>
</body>

</html>